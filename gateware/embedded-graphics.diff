+
+    /// Upload a spritesheet to the hardware with a unique identifier.
+    ///
+    /// If the key is already present in hardware, this is a no-op.
+    /// For targets that don't support hardware blitting, this can be a no-op that returns Ok(()).
+    ///
+    /// # Arguments
+    /// * `key` - Unique identifier for this spritesheet
+    /// * `pixels` - 1-bit pixel data (1=opaque, 0=transparent) 
+    /// * `width` - Width of the spritesheet in pixels
+    /// * `height` - Height of the spritesheet in pixels
+    fn upload_spritesheet(&mut self, key: u32, pixels: &[u8], width: u32, height: u32) -> Result<(), Self::Error> {
+        let _ = (key, pixels, width, height);
+        Ok(())
+    }
+
+    /// Blit a rectangular region from a spritesheet to the target.
+    ///
+    /// Default implementation does nothing and returns an error, indicating that hardware
+    /// blitting is not supported. Targets with hardware acceleration should override this.
+    ///
+    /// # Arguments
+    /// * `key` - Spritesheet identifier (must have been uploaded first)
+    /// * `src_x`, `src_y` - Source coordinates in the spritesheet
+    /// * `width`, `height` - Size of the region to blit
+    /// * `dst_x`, `dst_y` - Destination coordinates on the target
+    /// * `color` - Color to use for opaque pixels (implementation-specific format)
+    fn blit_sprite(&mut self, key: u32, src_x: u32, src_y: u32, width: u32, height: u32, dst_x: i32, dst_y: i32, color: Self::Color) -> Result<(), Self::Error> {
+        let _ = (key, src_x, src_y, width, height, dst_x, dst_y, color);
+        // Default: hardware blitting not supported, return success but do nothing
+        // The caller should check if the target actually supports blitting
+        Ok(())
+    }
 }
